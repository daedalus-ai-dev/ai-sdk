{
  "name": "@daedalus-ai-dev/ai-sdk",
  "version": "0.1.8",
  "description": "A TypeScript AI SDK for building agents, tools, and multi-agent workflows",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/daedalus-ai-dev/ai-sdk.git"
  },
  "homepage": "https://daedalus-ai-dev.github.io/ai-sdk/",
  "bugs": {
    "url": "https://github.com/daedalus-ai-dev/ai-sdk/issues"
  },
  "keywords": [
    "ai",
    "sdk",
    "agents",
    "llm",
    "tools",
    "mcp",
    "openai",
    "anthropic",
    "google",
    "multi-agent"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "zod": ">=3.0.0",
    "zod-to-json-schema": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": { "optional": true },
    "zod-to-json-schema": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitepress": "^1.6.4",
    "vitest": "^2.0.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/xai": "^3.0.67",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^6.0.116"
  }
}
